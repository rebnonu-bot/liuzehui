    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-rsc": "^0.5.20",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pagefind": "^1.4.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vinext": "^0.0.5",
    "vite": "^7.3.1",
    "wrangler": "^4.68.1"
