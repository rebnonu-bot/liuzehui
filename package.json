{
  "name": "luoleiorg-x",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm search:index && node scripts/dev-port.mjs",
    "build": "pnpm search:index && vinext build",
    "start": "vinext start",
    "dev:vinext": "pnpm search:index && node scripts/dev-port.mjs",
    "dev:vinext:raw": "pnpm search:index && vinext dev",
    "build:vinext": "pnpm search:index && vinext build",
    "deploy:vinext": "pnpm exec vinext deploy",
    "deploy:vinext:dry": "pnpm exec vinext deploy --dry-run",
    "deploy:vinext:preview": "pnpm exec vinext deploy --preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "sync:content": "node scripts/sync-content.mjs",
    "search:index": "node scripts/generate-search-index.mjs && node scripts/generate-pagefind-index.mjs",
    "search:json": "node scripts/generate-search-index.mjs",
    "search:pagefind": "node scripts/generate-pagefind-index.mjs"
  },
  "dependencies": {
    "@luoleiorg/search-core": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.15",
    "@types/hast": "^3.0.4",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.575.0",
    "medium-zoom": "^1.1.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tailwind-merge": "^3.5.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
